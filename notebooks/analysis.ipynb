    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# SBB Precipitation Study: Analysis Notebook\\n\",\n",
    "    \"\\n\",\n",
    "    \"Investigation of the correlation between precipitation and train delays at three major Swiss railway stations: Zürich HB, Basel SBB, and Bern.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Study period: 2024–2025\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 0. Setup\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from dotenv import load_dotenv\\n\",\n",
    "    \"import psycopg2\\n\",\n",
    "    \"from sqlalchemy import create_engine\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Configuration\\n\",\n",
    "    \"load_dotenv()\\n\",\n",
    "    \"plt.style.use('seaborn-v0_8-darkgrid')\\n\",\n",
    "    \"sns.set_palette(\\\"husl\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Database connection\\n\",\n",
    "    \"db_host = os.getenv(\\\"DB_HOST\\\", \\\"localhost\\\")\\n\",\n",
    "    \"db_port = os.getenv(\\\"DB_PORT\\\", \\\"5432\\\")\\n\",\n",
    "    \"db_name = os.getenv(\\\"DB_NAME\\\", \\\"sbb_precipitation\\\")\\n\",\n",
    "    \"db_user = os.getenv(\\\"DB_USER\\\", \\\"postgres\\\")\\n\",\n",
    "    \"db_password = os.getenv(\\\"DB_PASSWORD\\\", \\\"postgres\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"engine = create_engine(\\n\",\n",
    "    \"    f\\\"postgresql://{db_user}:{db_password}@{db_host}:{db_port}/{db_name}\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Database connected.\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Sanity check: row counts\\n\",\n",
    "    \"with engine.connect() as conn:\\n\",\n",
    "    \"    result = conn.execute(\\n\",\n",
    "    \"        \\\"SELECT 'train_connections' as table_name, COUNT(*) as count FROM train_connections UNION ALL \\\"\\n\",\n",
    "    \"        \\\"SELECT 'precipitation_10min', COUNT(*) FROM precipitation_10min UNION ALL \\\"\\n\",\n",
    "    \"        \\\"SELECT 'processing_log', COUNT(*) FROM processing_log\\\"\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    for row in result:\\n\",\n",
    "    \"        print(f\\\"{row[0]}: {row[1]} rows\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Data Validation\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Load data from analysis view\\n\",\n",
    "    \"df = pd.read_sql(\\\"SELECT * FROM analysis\\\", engine)\\n\",\n",
    "    \"print(f\\\"Loaded {len(df)} records from analysis view\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nColumns: {df.columns.tolist()}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nShape: {df.shape}\\\")\\n\",\n",
    "    \"df.head()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Check for NULLs in critical columns\\n\",\n",
    "    \"print(\\\"NULL counts in critical columns:\\\")\\n\",\n",
    "    \"print(df[['arrival_delay_min', 'median_precip_mm', 'trip_duration_min']].isnull().sum())\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Data types\\n\",\n",
    "    \"print(f\\\"\\\\nData types:\\\\n{df.dtypes}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Arrival delay distribution\\n\",\n",
    "    \"fig, ax = plt.subplots(1, 1, figsize=(10, 6))\\n\",\n",
    "    \"df['arrival_delay_min'].hist(bins=50, ax=ax)\\n\",\n",
    "    \"ax.set_xlabel('Arrival Delay (minutes)')\\n\",\n",
    "    \"ax.set_ylabel('Frequency')\\n\",\n",
    "    \"ax.set_title('Distribution of Arrival Delays')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Arrival delay stats:\\\")\\n\",\n",
    "    \"print(df['arrival_delay_min'].describe())\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Precipitation distribution\\n\",\n",
    "    \"fig, ax = plt.subplots(1, 1, figsize=(10, 6))\\n\",\n",
    "    \"df[df['median_precip_mm'].notna()]['median_precip_mm'].hist(bins=50, ax=ax)\\n\",\n",
    "    \"ax.set_xlabel('Median Precipitation (mm)')\\n\",\n",
    "    \"ax.set_ylabel('Frequency')\\n\",\n",
    "    \"ax.set_title('Distribution of Median Precipitation')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Precipitation stats (excluding NULLs):\\\")\\n\",\n",
    "    \"print(df[df['median_precip_mm'].notna()]['median_precip_mm'].describe())\\n\",\n",
    "    \"print(f\\\"\\\\nPrecipitation coverage: {(1 - df['median_precip_mm'].isnull().sum() / len(df)) * 100:.1f}% non-null\\\")\"\n",
    "   ]\n",
    "  },\n",
